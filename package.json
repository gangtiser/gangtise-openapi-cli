{
  "name": "gangtise-openapi-cli",
  "version": "0.10.0",
  "description": "CLI for Gangtise OpenAPI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gangtiser/gangtise-openapi-cli.git"
  },
  "bugs": {
    "url": "https://github.com/gangtiser/gangtise-openapi-cli/issues"
  },
  "homepage": "https://github.com/gangtiser/gangtise-openapi-cli#readme",
  "type": "module",
  "bin": {
    "gangtise": "dist/src/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepare": "node -e \"const p=JSON.parse(require('fs').readFileSync('package.json','utf8'));require('fs').writeFileSync('src/version.ts','// Auto-generated — DO NOT EDIT\\nexport const CLI_VERSION = \\\"'+p.version+'\\\"\\n')\" && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
