{
  "name": "gangtise-openapi-cli",
  "version": "0.28.1",
  "description": "CLI for Gangtise OpenAPI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gangtiser/gangtise-openapi-cli.git"
  },
  "bugs": {
    "url": "https://github.com/gangtiser/gangtise-openapi-cli/issues"
  },
  "homepage": "https://github.com/gangtiser/gangtise-openapi-cli#readme",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "gangtise": "dist/src/cli.js"
  },
  "files": [
    "dist/",
    "gangtise-openapi/",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "prepare": "node scripts/prepare.cjs && npm run build"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.6"
  }
}
